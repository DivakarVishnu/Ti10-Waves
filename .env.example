# ---- Ti10-Waves environment variables ----
# Copy to .env for local dev, or set these in Render's Environment tab.

SECRET_KEY=change-this-to-a-random-secret

# Postgres connection string (e.g. from Neon). Leave blank to fall back to local SQLite.
# Render/Neon may give you a "postgres://" URL — the app auto-converts it to "postgresql://".
DATABASE_URL=

# Default admin account, auto-created on first run if no admin exists yet.
DEFAULT_ADMIN_NAME=Administrator
DEFAULT_ADMIN_USERNAME=KITCSE
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=CSE4321

# Cloudinary — when set, ALL uploads (thumbnails, PDFs, Word docs) go to Cloudinary's
# persistent storage instead of local disk, so nothing is lost when Render wipes the
# filesystem on redeploy/restart. Get this from your Cloudinary dashboard's "API
# Environment variable" box. Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
# Leave blank to keep using local disk (fine for local dev, risky in production).
CLOUDINARY_URL=
CLOUDINARY_FOLDER=ti10-waves
